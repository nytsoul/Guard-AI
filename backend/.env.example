# Sentinel Shield â€“ Environment Variables
# Copy to .env and fill in values

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/sentinel_shield

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_key
JWT_EXPIRY_SECONDS=86400

# Google Gemini (Layer 3 â€“ primary LLM classifier)
GEMINI_API_KEY=AIzaSyD7tSNLsNao2QAp6Md6peLfO-XETogpExw
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT=10

# Local DistilBERT model (Layer 2)
# Place fine-tuned model in backend/models/injection_classifier/
# or leave blank to use HuggingFace hub fallback
LOCAL_MODEL_PATH=models/injection_classifier
LOCAL_MODEL_ENABLED=true

# Risk thresholds (overrides policy defaults at startup)
RISK_HIGH_THRESHOLD=70
RISK_MEDIUM_THRESHOLD=40

# Layer weights (must sum to 1.0)
WEIGHT_RULE=0.20
WEIGHT_LOCAL=0.30
WEIGHT_LLM=0.50

# Flask
FLASK_DEBUG=true
PORT=5000
SECRET_KEY=change_me_flask_secret

# CORS
CORS_ORIGINS=*
